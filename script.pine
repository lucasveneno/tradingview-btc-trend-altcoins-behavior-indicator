//@version=6
indicator("Indicador de Tendências do BTC e Altcoins", overlay=true)

trend_type =input.string(defval='2', options=['1', '2'], title='Tipo tendencia', inline='linha 1', group='Tipo de tendencia: 1=Fechamento do BTC 2=Basedo nas EMAs') 
// '1' representa a análise baseada no valor de fechamento do BTC.
// '2' representa a análise baseada na EMA (Média Móvel Exponencial).

// Create an input list for exchanges
exchange = input.string(title="Select Exchange", defval="BYBIT", options=["BINANCE", "BYBIT", "COINBASE", "KRAKEN"])
// Define the symbol for BTC/USDT on the selected exchange
btc_usd = exchange + ":BTCUSDT"
btc_dominance = "CRYPTOCAP:BTC.D"

// Configuração de EMAs
ema1 = input.int(20, title='EMA 1', inline='linha 31', group='Configuração de EMAs')            // Primeira EMA
colorEMA1 =input(color.yellow, '', inline='linha 31', group='Configuração de EMAs')           // Cor da primeira EMA
ema2 = input.int(50, title='EMA 2', inline='linha 31', group='Configuração de EMAs')            // Segunda EMA
colorEMA2 =input(color.rgb(93,96,107), '', inline='linha 31', group='Configuração de EMAs')   // Cor da segunda EMA
ema3 = input.int(100, title='EMA 3', inline='linha 32', group='Configuração de EMAs')           // Terceira EMA
colorEMA3 =input(color.blue, '', inline='linha 32', group='Configuração de EMAs')             // Cor da terceira EMA
ema4 =input.int(200, title='EMA 4', inline='linha 32', group='Configuração de EMAs')            // Quaarta EMA
colorEMA4 =input(color.red, '', inline='linha 32', group='Configuração de EMAs')              // Cor da quarta EMA
ma1 =input.int(200, title='MMA 1', inline='linha 33', group='Configuração de EMAs')             // Primeira MMA
colorEMA5 =input(color.orange, '', inline='linha 33', group='Configuração de EMAs')           // Cor da Primeira MMA
bool showEmaLines =input(true, title='Exibir Linhas no gráfico', inline='linha 34', group='Configuração de EMAs')    // Exibir Linhas das EMAS
bool showExtend =input(true, title='Mostrar extensão de Linhas das EMAs', inline='linha 35', group='Configuração de EMAs')    // Linhas Extendidas nas EMAS

Pos_tabela = input.string(defval=position.bottom_right, options=[position.top_left, position.top_center, position.top_right, position.middle_left, position.middle_center, position.middle_right, position.bottom_left, position.bottom_center, position.bottom_right],  title='Posição da Tabela', inline='linha 11', group='Tabela') //Escolhe a posição da tabela no gráfico
Border =input(color.new(color.gray,0), 'Cor da Borda', inline='linha 40', group='Tabela')       // Muda cor das Bordas do Gráfico
Background =input(color.new(color.gray,40), 'Cor de Fundo ', inline='linha 40', group='Tabela') // Muda cor do Fundo no Gráfico
Text_Color =input(color.white, 'Cor do Texto', inline='linha 41', group='Tabela')               // Muda cor do Texto no Gráfico
Text_Size =input.string(defval=size.small, options=[size.auto, size.small, size.normal, size.large], title='Tamanho do Texto', inline='linha 41', group='Tabela') // Escolhe o tamanho do texto no gráfico
SV_Cor =input(color.red, 'Caindo', inline='linha 42', group='Cores da Tendência') // Cor para tendências Baixa
SC_Cor =input(color.green, 'Subindo', inline='linha 42', group='Cores da Tendência') // Cor para Tendências Alta
SL_Cor =input(color.blue, 'Lateral', inline='linha 42', group='Cores da Tendência') // Cor para Tendências Lateral

N_Cor =input(#131722, 'Neutro', inline='linha 43', group='Cores do Resultado')  
S1X_Cor =input(#81c784, 'Subindo 1X', inline='linha 44', group='Cores do Resultado')  
S2X_Cor =input(#388e3c, 'Subindo 2X', inline='linha 44', group='Cores do Resultado')  
D1X_Cor =input(#f77c80, 'Caindo 1X', inline='linha 45', group='Cores do Resultado')  
D2X_Cor =input(#b22833, 'Caindo 2X', inline='linha 45', group='Cores do Resultado')  

// Tendência em função das EMAs 20/200 quando o ativo está acima das EMAs - alta, abaixo das EMAs - baixa, entre as EMAs - lateral. Pega os valores de RSI em todos os tempos gráficos
TrendRef = ta.ema(close, 1)
EMA_REF_1 = ta.ema(close, ema1)
EMA_REF_2 = ta.ema(close, ema2)
EMA_REF_3 = ta.ema(close, ema3)
EMA_REF_4 = ta.ema(close, ema4)
EMA_REF_5 = ta.sma(close, ma1)

// Função para buscar EMAs em diferentes timeframes
getEMA(ema) =>
    request.security(syminfo.tickerid, timeframe.period, ema)

// Recebe as EMAs para o timeframe atual
EMA_PLOT_1 = getEMA(EMA_REF_1)
EMA_PLOT_2 = getEMA(EMA_REF_2)
EMA_PLOT_3 = getEMA(EMA_REF_3)
EMA_PLOT_4 = getEMA(EMA_REF_4)
EMA_PLOT_5 = getEMA(EMA_REF_5)

// Plota as EMAs e MA se showEmas for verdadeiro
plot(EMA_PLOT_1, title='EMA 1', color=colorEMA1, linewidth=2, display=showEmaLines ? display.all : display.none)
plot(EMA_PLOT_2, title='EMA 2', color=colorEMA2, linewidth=2, display=showEmaLines ? display.all : display.none)
plot(EMA_PLOT_3, title='EMA 3', color=colorEMA3, linewidth=2, display=showEmaLines ? display.all : display.none)
plot(EMA_PLOT_4, title='EMA 4', color=colorEMA4, linewidth=3, display=showEmaLines ? display.all : display.none)
plot(EMA_PLOT_5, title='MA 1', color=colorEMA5, linewidth=3, display=showEmaLines ? display.all : display.none)

// Função para desenhar linhas estendidas
linhaextendida(linhaEMA, corEMA, largEMA, nomeEMA) =>
    lineEMA = line.new(x1=bar_index, y1=linhaEMA, x2=bar_index + 4, y2=linhaEMA, color=corEMA, width=largEMA)
    line.delete(lineEMA[1])
    var lineEMALabel = label.new(x=bar_index + 4, y=linhaEMA, style=label.style_label_left, color=color.rgb(100, 100, 1, 100), textcolor=corEMA, text=nomeEMA)
    label.set_xy(lineEMALabel, x=bar_index + 4, y=linhaEMA)

// Aplica linhas estendidas se ativado
if showExtend
    linhaextendida(EMA_REF_1[0], colorEMA1, 2, 'EMA '+str.tostring(ema1))
    linhaextendida(EMA_REF_2[0], colorEMA2, 2, 'EMA '+str.tostring(ema2))
    linhaextendida(EMA_REF_3[0], colorEMA3, 2, 'EMA '+str.tostring(ema3))
    linhaextendida(EMA_REF_4[0], colorEMA4, 3, 'EMA '+str.tostring(ema4))
    linhaextendida(EMA_REF_5[0], colorEMA5, 3, 'MA '+str.tostring(ma1))

// Função para verificar tendência de alta ou baixa
//get_trend(symbol, timeframe) =>
//    close_current = request.security(symbol, timeframe, close)
//    close_previous = request.security(symbol, timeframe, close[1])
